                    "Utilisateur"
                ],
                "summary": "Inscription de l'utilisateur",
                "operationId": "d3d2dd59f195539f66a5649d47c47727",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email",
                                    "password"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "example": "user@example.com"
                                    },
                                    "mdp": {
                                        "type": "string",
                                        "example": "password123"
                                    },
                                    "pseudo": {
                                        "type": "string",
                                        "example": "user"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Inscription réussie",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "string",
                                            "example": "succes"
                                        },
                                        "data": {
                                            "properties": {
                                                "message": {
                                                    "type": "string",
                                                    "example": "Code PIN envoyé à user@example.com"
                                                }
                                            },
                                            "type": "object"
                                        },
                                        "meta": {
                                            "type": "array",
                                            "items": {
                                                "type": "string",
                                                "example": "null"
                                            },
                                            "example": null,
                                            "nullable": true
                                        },
                                        "error": {
                                            "type": "string",
                                            "example": null,
                                            "nullable": true
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Données invalides"
                    }
                }
            }
        },
